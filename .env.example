# Copy to docker/.env and adjust values before running docker compose

# ── Olama (LLM engine) ────────────────────────────────────────────────────────

# Host port for the raw Ollama API (used by other tools or for direct API calls)
OLLAMA_PORT=11434

# Ollama Docker image version (use 'latest' or a specific tag like '0.3.14')
OLLAMA_VERSION=latest

# Host path for persistent model storage (CLI install only)
OLLAMA_DATA_DIR=/opt/olama

# Model to pull automatically on first container start
# Default: mistral (~4.1 GB, well-rounded general model)
# Leave empty to pull models manually later
# Other options: llama3.2:1b  llama3.2:3b  phi3:mini  codellama:7b  llama3.1:8b
OLLAMA_PULL_MODEL=mistral

# ── Open WebUI (chat interface) ───────────────────────────────────────────────

# Host port for the chat UI — open http://localhost:3000 in your browser
WEBUI_PORT=3000

# ── SearXNG (web search) ──────────────────────────────────────────────────────
# SearXNG has no host port — it is internal only.
# Web search is OFF by default in the UI; toggle it per message when needed.
# To change the secret key, edit docker/searxng/settings.yml
