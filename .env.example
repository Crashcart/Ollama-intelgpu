# Copy this file to docker/.env before running docker compose.
# All paths under DATA_DIR are bind-mounted to the host, so every byte of
# data is exportable — just copy or rsync the DATA_DIR tree.

# =============================================================================
#  STORAGE  —  set DATA_DIR to wherever you have enough space
#              (external drive, NAS mount, second disk, etc.)
# =============================================================================

# Root directory for ALL persistent data and logs.
# Subdirectories are created automatically on first start.
#
#   ${DATA_DIR}/models/     — Ollama LLM model weights   (can reach 100+ GB)
#   ${DATA_DIR}/webui/      — Chat history, RAG docs, ChromaDB, user settings
#   ${DATA_DIR}/searxng/    — SearXNG config (settings.yml)
#   ${DATA_DIR}/pipelines/  — Pipeline scripts (.py); drop files here to add tools
#   ${DATA_DIR}/logs/       — Exported log files (written by scripts/logs.sh)
#
# Change this to an external drive path, e.g. /mnt/data or /media/user/disk
DATA_DIR=/opt/ollama

# =============================================================================
#  OLLAMA  —  LLM engine (Intel GPU)
# =============================================================================

# Host port for the raw Ollama API
OLLAMA_PORT=11434

# Ollama image tag — pin to a specific version to avoid silent breaking changes.
# Update deliberately rather than tracking 'latest'.
OLLAMA_VERSION=0.6.5

# Group IDs for Intel GPU device access.
# install.sh detects these automatically from the host and writes them here.
# If you're editing docker/.env by hand, run:
#   getent group video | cut -d: -f3   → VIDEO_GID
#   getent group render | cut -d: -f3  → RENDER_GID
# Defaults cover typical Ubuntu installations.
VIDEO_GID=44
RENDER_GID=993

# =============================================================================
#  MULTI-APP QUEUING  —  how Ollama handles requests from multiple clients
#
#  All apps (Open WebUI, Cursor, VS Code extensions, custom scripts, etc.)
#  share the same port 11434.  Ollama queues requests natively — no proxy
#  or middleware needed.
#
#  How it works:
#    1. App sends a request to :11434
#    2. If a slot is free (NUM_PARALLEL), it runs immediately
#    3. If not, it waits in the queue (up to MAX_QUEUE deep)
#    4. If the queue is full, Ollama returns 503 — caller should retry
# =============================================================================

# How many requests run simultaneously on the GPU.
# Keep at 1 for Intel GPU — running parallel requests splits VRAM and slows
# everything down.  Raise only if your GPU has spare headroom.
OLLAMA_NUM_PARALLEL=1

# Maximum number of requests allowed to wait before Ollama rejects new ones.
# 100 is more than enough for personal or small-team use.
OLLAMA_MAX_QUEUE=100

# Number of models to keep loaded in VRAM at the same time.
# 1 is correct for most Intel GPU setups.  Increase if you frequently switch
# between models AND have enough VRAM to hold multiple simultaneously.
OLLAMA_MAX_LOADED_MODELS=1

# How long to keep a model in VRAM after its last request.
# 5m  — unload after 5 minutes idle (Ollama default, good balance)
# 0   — unload immediately after each request (maximum VRAM savings)
# -1  — keep loaded forever until container restarts
OLLAMA_KEEP_ALIVE=5m

# Allowed origins for the Ollama HTTP API (CORS + host-header check).
# Ollama uses prefix matching — 'http://192.168.' permits any IP in that subnet.
# The default covers all RFC-1918 private ranges and Docker bridge networks so
# LAN clients (Cursor, VS Code, Akimo AI, etc.) connect without extra config,
# while requests from internet origins are blocked.
# Add your subnet prefix here if your LAN uses a different range:
#   VPN / ZeroTier  →  append e.g. http://192.168.191.  (use your ZeroTier subnet)
#   Tailscale       →  append http://100.
# NOTE: ZeroTier users must use the ZeroTier IP in the browser, not .local —
#       mDNS hostnames do not propagate over ZeroTier tunnels.
OLLAMA_ORIGINS=http://localhost,https://localhost,http://127.0.0.1,http://192.168.,http://10.,http://172.

# =============================================================================
#  OPEN WEBUI  —  chat interface
# =============================================================================

# Host port for the chat UI  →  http://localhost:45213
WEBUI_PORT=45213

# Pre-select a model for new conversations. Must match a pulled model name.
# Leave empty to let users pick from the model dropdown.
DEFAULT_MODELS=

# Log verbosity for Open WebUI (INFO | WARNING | ERROR | DEBUG)
# Use DEBUG when investigating issues — logs become very detailed.
WEBUI_LOG_LEVEL=INFO

# =============================================================================
#  AUTH / USER MANAGEMENT  —  multi-user login system
#
#  WEBUI_AUTH=true enables login-protected accounts.
#  The first user to register automatically becomes the admin.
#  Set ENABLE_SIGNUP=false to prevent new users from self-registering.
#  WEBUI_SECRET_KEY is the JWT signing secret — set it explicitly so
#  user sessions survive container restarts.
# =============================================================================

WEBUI_AUTH=true
ENABLE_SIGNUP=true
# Auto-generated by install.sh on first run — do not leave empty in production.
# Regenerate: openssl rand -hex 32
WEBUI_SECRET_KEY=

# =============================================================================
#  PIPELINES  —  tool and function runtime for Open WebUI
#
#  Pipelines appear alongside Ollama models in Open WebUI and can:
#    • Execute custom Python tools and functions
#    • Filter or transform messages before/after the LLM
#    • Rate-limit requests per user or model
#    • Track token usage and cost across sessions
#    • Run any logic that would be awkward inside a prompt
#
#  To add a pipeline:
#    1. Drop a .py file into ${DATA_DIR}/pipelines/
#    2. Open WebUI → Admin → Settings → Pipelines → click reload
#
#  Browse ready-made pipelines:
#    https://github.com/open-webui/pipelines/tree/main/examples
# =============================================================================

# Shared secret between pipelines and open-webui.
# Auto-generated by install.sh on first run — never use the default on a real network.
PIPELINES_API_KEY=

# =============================================================================
#  RAG  —  document question & answer (PDF, DOCX, TXT, URLs)
#
#  Upload documents via the paperclip icon in any chat.  Open WebUI chunks
#  and embeds them locally using sentence-transformers — no extra model pull
#  needed.  Chunks are stored in ${DATA_DIR}/webui (ChromaDB).
#
#  Tip: for better embedding quality on longer documents, consider switching
#  RAG_EMBEDDING_ENGINE to "ollama" and pulling nomic-embed-text:
#    docker exec ollama ollama pull nomic-embed-text
#  Then set in docker/.env:
#    RAG_EMBEDDING_ENGINE=ollama
#    RAG_EMBEDDING_MODEL=nomic-embed-text:latest
# =============================================================================

# Text chunk size for document splitting (characters).
# Larger = more context per chunk; smaller = more precise retrieval.
CHUNK_SIZE=1500
CHUNK_OVERLAP=100

# =============================================================================
#  AUDIO  —  voice input and output
#
#  STT (Speech-to-Text): click the microphone icon in the chat bar to dictate.
#  Uses faster-whisper running inside the Open WebUI container — no extra
#  service or model pull required.
#
#  TTS (Text-to-Speech): click the speaker icon next to any response to hear
#  it read aloud.  Browser-native TTS is used by default (no extra setup).
#  For higher-quality voices, add a Kokoro TTS pipeline (see pipelines above).
# =============================================================================

# STT engine: whisper (local, default) | openai (if you have an API key)
AUDIO_STT_ENGINE=whisper

# Whisper model size. Larger = more accurate but slower and more VRAM.
# tiny | base (default) | small | medium | large-v3
WHISPER_MODEL=base

# TTS engine: empty = browser-native (default) | openai = Kokoro pipeline
AUDIO_TTS_ENGINE=

# =============================================================================
#  IMAGE GENERATION  —  generate images from the chat bar
#
#  Disabled by default.  To enable:
#    1. Add an AUTOMATIC1111 or ComfyUI service to docker/docker-compose.yml
#    2. Set ENABLE_IMAGE_GENERATION=true below
#    3. Restart: docker compose up -d
#  A camera icon will appear in the chat bar when active.
#
#  Quick AUTOMATIC1111 service to add to docker-compose.yml:
#    automatic1111:
#      image: universonic/stable-diffusion-webui:latest
#      container_name: automatic1111
#      environment:
#        - COMMANDLINE_ARGS=--api --listen --nowebui
#      volumes:
#        - ${DATA_DIR}/sd-models:/app/models
#      networks:
#        - ollama_net
# =============================================================================

ENABLE_IMAGE_GENERATION=false
# automatic1111 (default) | comfyui | openai (DALL-E)
IMAGE_GENERATION_ENGINE=automatic1111
# URL of your image generation service (only used when enabled above)
AUTOMATIC1111_BASE_URL=http://automatic1111:7860

# =============================================================================
#  YOUTUBE TRANSCRIPTS  —  load video content as RAG context
#
#  Paste a YouTube URL into any chat. Open WebUI fetches the transcript and
#  feeds it to the model so it can answer questions about the video.
# =============================================================================

# Language code for YouTube transcript extraction (e.g. en, es, fr, de, ja)
YOUTUBE_LOADER_LANGUAGE=en

# =============================================================================
#  COMMUNITY SHARING  —  share prompts to the Open WebUI community hub
#
#  When enabled, a "Share" button appears on custom prompts and modelfiles.
#  Shared items are uploaded to the public Open WebUI community directory.
# =============================================================================

ENABLE_COMMUNITY_SHARING=false

# =============================================================================
#  SEARXNG  —  web search backend (internal only, no host port)
# =============================================================================
# Web search is OFF by default. Toggle it per message in the chat UI.
# Edit ${DATA_DIR}/searxng/settings.yml to change the secret_key and engines.

# =============================================================================
#  LOG VIEWER  —  real-time web UI for container logs (Dozzle)
# =============================================================================

# =============================================================================
#  GHOST RUNNER  —  background task generation with resume support
# =============================================================================

# Host port for the Ghost Runner UI  →  http://localhost:45215
# Submit prompts that run in the background even after you close the browser.
# All tokens are persisted to ${DATA_DIR}/ghost/ghost.db — reconnect anytime
# to replay the full output from any point using SSE sequence IDs.
GHOST_RUNNER_PORT=45215

# =============================================================================
#  MEMORY BROWSER  —  persistent AI memory store (SQLite-backed)
# =============================================================================

# Host port for the Memory Browser UI  →  http://localhost:45216
# Stores facts the AI learns about you or the environment.  Pinned memories are
# injected into every new conversation via GET /api/memories/pinned.
MEMORY_PORT=45216

# =============================================================================
#  FILE CATALOG  —  large-file browser with external drive offload
# =============================================================================

# Host port for the File Catalog UI  →  http://localhost:45217
# Scans DATA_DIR for large files (models, DBs) and lets you move them to a
# mounted external drive with automatic symlinks back so all paths keep working.
FILE_CATALOG_PORT=45217

# Minimum file size (MB) to include in the catalog.  Default: 100
FILE_CATALOG_MIN_MB=100

# Host path where external drives are mounted.  The catalog shows all
# subdirectories here as selectable destination drives.
# Example: if you mount an external SSD at /mnt/bigdrive, set DRIVES_DIR=/mnt
DRIVES_DIR=/mnt

# =============================================================================
#  LOG VIEWER  —  real-time web UI for container logs (Dozzle)
# =============================================================================

# Host port for the Dozzle web log viewer  →  http://localhost:9999
# Open in your browser to see live logs from all stack containers in one tab.
# Use this to share log output when reporting issues.
DOZZLE_PORT=9999

# Minimum log level shown in the Dozzle browser UI.
# info  → all normal operational messages (default — recommended for diagnosis)
# warn  → warnings and above only (quieter)
# error → errors and critical only (very quiet)
DOZZLE_LEVEL=info

# =============================================================================
#  LOG ROTATION  —  applies to all containers via Docker json-file driver
# =============================================================================

# Maximum size of a single log file before it rotates.
# In debug mode this grows fast — scripts/logs.sh debug-on raises it to 50m.
LOG_MAX_SIZE=10m

# Number of rotated files to keep per container (older files are deleted).
# 5 files × 10 MB = up to 50 MB of logs per container (normal mode).
LOG_MAX_FILES=5

# =============================================================================
#  DEBUG MODE  —  increases log verbosity across all containers
#
#  Do not edit these manually — use the log helper instead:
#    bash scripts/logs.sh debug-on      enable deep logging + auto-restart
#    bash scripts/logs.sh debug-off     restore normal logging + auto-restart
#    bash scripts/logs.sh status        see current debug state per container
#
#  What changes in debug mode:
#    ollama      OLLAMA_DEBUG 0→1        GPU selection, model load steps,
#                                       per-token generation traces
#    open-webui WEBUI_LOG_LEVEL INFO→DEBUG  every HTTP request, RAG retrieval,
#                                       embedding calls, search results
#    searxng    SEARXNG_DEBUG false→true  per-engine request/response,
#                                       result ranking and deduplication
#    rotation   LOG_MAX_SIZE 10m→50m   larger files to avoid dropping
#               LOG_MAX_FILES 5→10     more history kept during debug sessions
# =============================================================================

DEBUG_MODE=false
OLLAMA_DEBUG=0
SEARXNG_DEBUG=false
# Note: WEBUI_LOG_LEVEL is defined in the OPEN WEBUI section above.
# scripts/logs.sh debug-on/off updates it there automatically.

# =============================================================================
#  DNS  —  override the public DNS resolvers used inside containers
#  Useful when corporate firewalls block 1.1.1.1/8.8.8.8 or you prefer
#  a local resolver (e.g. Pi-hole at 192.168.1.1).
# =============================================================================
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=8.8.8.8

# =============================================================================
#  PROJECT  —  prefix used for Docker container names (default: ollama)
#  Change this if you run multiple independent stacks on the same Docker host
#  to avoid container name collisions (see install.sh --force to bypass checks).
# =============================================================================
PROJECT_PREFIX=ollama
